#!/usr/bin/env python3
"""
pegare — Simple launcher script for PegaRE auto-dispatcher.

This provides a convenient command-line interface that users can add to their PATH.
"""
import sys
from pathlib import Path

# Add the package directory to Python path
package_dir = Path(__file__).parent / "pega_re"
sys.path.insert(0, str(package_dir.parent))

from pega_re.auto_dispatcher import main

if __name__ == "__main__":
    exit(main())
