    "skills/kyc-domain/regulatory-framework.md",
    "skills/kyc-domain/risk-scoring.md",
    "skills/kyc-domain/approval-flows.md",
    "skills/kyc-domain/external-services.md",
    "skills/document-templates/frd-template.md"
